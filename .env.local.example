# Local-dev environment variables.
# Copy to .env.local and fill in real values:  cp .env.local.example .env.local
# For the deployed Vercel build, set the same keys under:
#   Vercel project → Settings → Environment Variables

# Vercel Postgres / Neon / Supabase connection string
DATABASE_URL=

# Generate: openssl rand -base64 32
JWT_SECRET=
